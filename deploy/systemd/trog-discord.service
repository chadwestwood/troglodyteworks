[Unit]
Description=Troglodyte Works Discord Bot
After=network-online.target postgresql.service
Wants=network-online.target

[Service]
Type=simple
User=cdubbs
WorkingDirectory=/srv/troglodyteworks/backend/genesis
EnvironmentFile=/srv/troglodyteworks/backend/genesis/.env
ExecStart=/srv/troglodyteworks/backend/genesis/.venv/bin/python -m twe.discord_bot.service
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
