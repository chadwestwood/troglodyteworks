TWE_DATABASE_URL=postgresql://twe_app:replace-with-password@localhost:5432/twe
# Integration tests fail closed unless this names a dedicated *_test database.
TWE_TEST_DATABASE_URL=postgresql://twe_app:replace-with-password@localhost:5432/twe_test
TWE_INITIAL_USER_EMAIL=chad@example.com
TWE_INITIAL_USER_PASSWORD=replace-with-initial-password
TWE_INITIAL_USER_DISPLAY_NAME=Chad
TWE_SESSION_COOKIE_NAME=twe_session
TWE_SESSION_DAYS=7
TWE_COOKIE_SECURE=false
TWE_BIND_HOST=0.0.0.0
TWE_BIND_PORT=8787
TWE_ADMIN_EMAILS=chad@example.com
TWE_GOOGLE_CLIENT_ID=
TWE_GOOGLE_CLIENT_SECRET=
TWE_GOOGLE_REDIRECT_URI=
TWE_ASA_EXPECTED_PROCESS=
TWE_ASA_HEALTH_HOST=
TWE_ASA_HEALTH_PORT=
TWE_ASA_RCON_HOST=
TWE_ASA_RCON_PORT=
TWE_ASA_RCON_PASSWORD=
# Local ASA panel JSON used to read the active Genesis mod list.
TWE_ASA_PANEL_CONFIG_PATH=/opt/asa-control-panel/config.json
TROG_DISCORD_BOT_TOKEN=
TROG_DISCORD_CLIENT_ID=
TROG_DISCORD_CLIENT_SECRET=
# Account sign-in/link callback, for example https://example.test/api/v1/auth/discord/callback
TROG_DISCORD_REDIRECT_URI=
# Guild verification and bot-install callback, for example https://example.test/api/v1/discord/oauth/callback
TROG_DISCORD_INSTALL_REDIRECT_URI=
TROG_DISCORD_BOT_PERMISSIONS=
# Temporary read-only compatibility fallback; prefer discord_guild_installations.
TROG_DISCORD_GUILD_GAME_SERVER_MAP=
TROG_DISCORD_LOG_LEVEL=INFO
# AES-256-GCM provider credential keys. Keep real values out of source control.
# Retain old versions here while ciphertext encrypted with them still exists.
# JSON shape: {"v1":"<standard-base64-encoded 32-byte key>"}
# Generate and install a key without printing it:
#   .venv/bin/python scripts/configure_provider_secret_key.py --version v1
TWE_PROVIDER_SECRET_ACTIVE_KEY_VERSION=
TWE_PROVIDER_SECRET_KEYS_JSON=
TWE_NITRADO_API_BASE_URL=https://api.nitrado.net
TWE_NITRADO_TIMEOUT_SECONDS=8
TWE_ASA_MOD_CATALOG_PATH=/app/backend/trog/data/asa_mod_catalog.json
TWE_CURSEFORGE_API_BASE_URL=https://api.curseforge.com
TWE_CURSEFORGE_API_KEY=
